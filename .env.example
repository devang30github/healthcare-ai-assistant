# ── LLM Providers ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Ollama ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2B

# ── Embedding ───────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Retrieval ───────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80
TOP_K=3
BM25_TOP_K=5
FAISS_TOP_K=5
CONFIDENCE_HIGH=0.75
CONFIDENCE_LOW=0.50

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
